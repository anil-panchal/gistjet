{
  "name": "gistjet",
  "version": "0.0.0",
  "description": "Local-workspace-aware MCP server that publishes and syncs files to GitHub Gists over stdio.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "github",
    "gist",
    "gists",
    "sync",
    "cli",
    "claude",
    "agent-tools"
  ],
  "author": "Anil Panchal",
  "license": "MIT",
  "homepage": "https://github.com/YOUR_USERNAME/gistjet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_USERNAME/gistjet.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/gistjet/issues"
  },
  "type": "module",
  "bin": {
    "gistjet": "./dist/bin/gistjet.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsup",
    "prepare": "husky || true",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/plugin-throttling": "^9.3.2",
    "@octokit/rest": "^22.0.0",
    "diff": "^5.2.0",
    "ignore": "^5.3.2",
    "pino": "^9.5.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/node": "^20.17.9",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "fast-check": "^3.23.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "msw": "^2.7.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
